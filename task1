import pandas as pd

# 1. Load the dataset
# Make sure 'titanic.csv' is in the same folder as this script
df = pd.read_csv('titanic.csv')

# 2. View the first 5 rows
print("--- First 5 rows of the dataset ---")
print(df.head())

# 3. Get a summary of the data
print("\n--- Summary Info ---")
print(df.info())

# 4. Check how many missing values we have in each column
print("\n--- Missing Values Count ---")
print(df.isnull().sum())

# 1. Fill missing 'Age' values with the mean (average) age
df['Age'] = df['Age'].fillna(df['Age'].mean())

# 2. Fill missing 'Embarked' values with the mode (the most frequent value)
# We use [0] because mode() returns a Series
df['Embarked'] = df['Embarked'].fillna(df['Embarked'].mode()[0])

# 3. Drop the 'Cabin' column as it has too many missing values
df = df.drop(columns=['Cabin'])

# 4. Verify that there are no missing values left
print("\n--- Missing Values After Cleaning ---")
print(df.isnull().sum())

# 1. Convert 'Sex' column: male -> 0, female -> 1
df['Sex'] = df['Sex'].map({'male': 0, 'female': 1})

# 2. Convert 'Embarked' column using one-hot encoding
# This creates new columns for each embarkation point (C, Q, S)
df = pd.get_dummies(df, columns=['Embarked'], dtype=int)

# 3. View the first 5 rows to see the changes
print("\n--- After Encoding ---")
print(df[['Sex', 'Embarked_C', 'Embarked_Q', 'Embarked_S']].head())

from sklearn.preprocessing import StandardScaler

# Initialize the scaler
scaler = StandardScaler()

# Define the numerical columns we want to scale
# We select 'Age' and 'Fare' as they are our main numerical features
numerical_cols = ['Age', 'Fare']

# Apply the scaling
df[numerical_cols] = scaler.fit_transform(df[numerical_cols])

# Verify the result
print("\n--- Summary Statistics After Scaling ---")
print(df[['Age', 'Fare']].describe().round(2))

import matplotlib.pyplot as plt
import seaborn as sns

# 1. Visualize outliers using boxplots
plt.figure(figsize=(10, 5))
sns.boxplot(data=df[['Age', 'Fare']])
plt.title("Boxplot of Age and Fare (Before Removing Outliers)")
plt.show()

# 2. Remove outliers using IQR (Interquartile Range)
Q1 = df[['Age', 'Fare']].quantile(0.25)
Q3 = df[['Age', 'Fare']].quantile(0.75)
IQR = Q3 - Q1

# Filter the data
df_clean = df[~((df[['Age', 'Fare']] < (Q1 - 1.5 * IQR)) | (df[['Age', 'Fare']] > (Q3 + 1.5 * IQR))).any(axis=1)]

print(f"\nOriginal dataset shape: {df.shape}")
print(f"Cleaned dataset shape: {df_clean.shape}")